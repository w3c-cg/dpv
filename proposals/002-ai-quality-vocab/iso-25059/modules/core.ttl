    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Dimension ;
    skos:definition "Degree to which an AI service provides consistent and stable AI service outcomes"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Service Reliability"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:ServiceSecurity a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.3, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
