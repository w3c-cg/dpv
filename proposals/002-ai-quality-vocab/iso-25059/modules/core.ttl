    skos:definition "Degree to which an AI service can be effectively and efficiently modified without introducing defects or degrading existing AI service quality"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Service Modifiability"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:ServiceOperability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.2.3, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:ServiceUsability ;
    skos:definition "Degree to which an AI service has attributes that make it easy to operate and control"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Service Operability"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:ServiceRecoverability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
