    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Service Security"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:ServiceTestability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.8.3,  IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
