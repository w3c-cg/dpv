@prefix sw: <http://www.w3.org/2003/06/sw-vocab-status/ns#> .
@prefix vann: <http://purl.org/vocab/vann/> .

iso-25059:AIServiceQuality a rdfs:Class,
        skos:Concept,
        dqv:Category ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Category ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "AI Service Quality"@en .

iso-25059:Acceptability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25019:2023,3.2.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Dimension ;
    skos:definition "Extent to which a human response is favourable when accepting or installing a product, system or service software tool designed to perform some frequently used function"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Acceptability"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:Accessibility a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25019:2023,3.2.1.2"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Beneficialness ;
    skos:definition "Extent to which products, systems, services, environments and facilities can be used by people from a population with the widest range of user needs, characteristics and capabilities to achieve identified goals in identified contexts of use"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Service Accessibility"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:Accountability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.6.4"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Security ;
    skos:definition "Capability of a product to enable actions of an entity to be traced uniquely to the entity"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Accountability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Adaptability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.8.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Flexibility ;
    skos:definition "Capability of a product to be effectively and efficiently adapted for or transferred to different hardware, software or other operational or usage environments"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Adaptability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Analysability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.7.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Maintainability ;
    skos:definition "Capability of a product to be effectively and efficiently assessed regarding the impact of an intended change to one or more of its parts, to diagnose it for deficiencies or causes of failures, or to identify parts to be modified"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Analysability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Appropriateness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.1.3, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Suitability ;
    skos:definition "Degree to which an IT service provides results that are appropriate for the user  needs"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Appropriateness"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:AppropriatenessRecognizability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.4.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:InteractionCapability ;
    skos:definition "Capability of a product to be recognized by users as appropriate for their needs"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Appropriateness Recognizability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Authenticity a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.6.5"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Security ;
    skos:definition "Capability of a product to prove that the identity of a subject or resource is the one claimed"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Authenticity"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Availability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.5.2"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Reliability ;
    skos:definition "Capability of a product to be operational and accessible when required for use"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Availability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Beneficialness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25019:2023,3.2.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Dimension ;
    skos:definition "Extent of benefit resulting from the use of a product, system or service"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Beneficialness"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:Capacity a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.2.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:PerformanceEfficiency ;
    skos:definition "Capability of a product to meet requirements for the maximum limits of a product parameter"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Capacity"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Coexistence a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.3.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Compatibility ;
    skos:definition "Capability of a product to perform its required functions efficiently while sharing a common environment and resources with other products, without detrimental impact on any other product"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Co-existence"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Compatibility a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Dimension ;
    skos:definition "Capability of a product to exchange information with other products, and/or to perform its required functions while sharing the same common environment and resources"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Compatibility"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Completeness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.1.1, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Suitability ;
    skos:definition "Degree to which an AI service supports all the specified goals, objectives and data specified by the user"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Completeness"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:Compliance a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25019:2023,3.2.3.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Acceptability ;
    skos:definition "Extent to which a user or other stakeholder has confidence that a product, system, software, or service in use meets requirements, as required by rules or laws"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Compliance"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:Confidentiality a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.6.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Security ;
    skos:definition "Capability of a product to ensure that data are accessible only to those authorized to have access"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Confidentiality"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Consistency a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.1.4, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Suitability ;
    skos:definition "Degree to which repeated or similar related IT services provided consistent quality"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Consistency"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:Continuity a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.4.1, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:ServiceReliability ;
    skos:definition "Degree to which the AI service is provided under all foreseeable circumstances, including mitigating the risks resulting from interruption to an acceptable level"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Continuity"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:Correctness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.1.2, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Suitability ;
    skos:definition "Degree to which an IT service uses the correct process and produces the correct results with accurate data"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Correctness"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:Courtesy a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.2.6, IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:ServiceUsability ;
    skos:definition "Degree to which the AI service is provided in a polite, respectful and friendly way"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Courtesy"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:Customizability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC DIS 25059:2025, 3.4.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:ServiceAdaptability ;
    skos:definition "Degree to which the AI service can be customized at the request of users"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Customizability"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:EconomicRiskMitigation a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "Definition of freedom from economic risk, ISO/IEC 25019:2023,3.2.2.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:RiskMitigation ;
    skos:definition "Extent to which a product or system mitigates the potential risk to financial status, efficient operation, commercial property, reputation, or other aspects in the intended contexts of use"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "EconomicRiskMitigation"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:EnvironmentalRiskMitigation a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC DIS 25059:2025. 3.3.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:RiskMitigation ;
    skos:definition "Degree to which a product or system mitigates the potential risk to the environment in the intended contexts of use"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Environmental Risk Mitigation"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:EnvironmentalSustainability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC DIS 25059:2025, 3.2.6"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:PerformanceEfficiency ;
    skos:definition "State in which the ecosystem and its functions are maintained for the present and future generations"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Environmental Sustainability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Experience a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25019:2023,3.2.3.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Acceptability ;
    skos:definition "Extent to which users or stakeholders accumulate knowledge or skill acquired over time, especially that gained in a particular profession"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Experience"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:FailSafe a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.9.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Safety ;
    skos:definition "Capability of a product to automatically place itself in a safe operating mode, or to revert to a safe condition in the event of a failure"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Fail Safe"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:FaultTolerance a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.5.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Reliability ;
    skos:definition "Capability of a product to operate as intended despite the presence of hardware or software faults"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Fault Tolerance"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Faultlessness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.5.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Reliability ;
    skos:definition "Capability of a product to perform specified functions without fault under normal operation"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Faultlessness"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Flexibility a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.8"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Dimension ;
    skos:definition "Capability of a product to be adapted to changes in its requirements, contexts of use, or system environment"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Flexibility"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:FunctionalAdaptability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25059:2023, 3.2.2 & ISO/IEC DIS 25059:2025, 3.2.2"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:FunctionalSuitability ;
    skos:definition """Degree to which an AI system can accurately acquire information from data, or the result of previous actions,
and use that information in future predictions"""@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Functional Adaptability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:FunctionalAppropriateness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.1.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:FunctionalSuitability ;
    skos:definition "Capability of a product to provide functions that facilitate the accomplishment of specified tasks and objectives."@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Functional Appropriateness"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:FunctionalCompleteness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.1.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:FunctionalSuitability ;
    skos:definition "Capability of a product to provide a set of functions that covers all the specified tasks and intended users’ objectives."@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Functional Completeness"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:FunctionalCorrectness a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25059:2023, 3.2.3 & ISO/IEC DIS 25059:2025, 3.2.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:FunctionalSuitability ;
    skos:definition "Degree to which a product or system provides the correct results with the needed degree of precision"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Functional Correctness"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:FunctionalSuitability a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.1"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Dimension ;
    skos:definition "Capability of a product to provide functions that meet stated and implied needs of intended users when it is used under specified conditions."@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Functional Suitability"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:HazardWarning a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.9.4"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:Safety ;
    skos:definition "Capability of a product to provide warnings of unacceptable risks to operations or internal controls so that they can react in sufficient time to sustain safe operations"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Hazard Warning"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:HealthRiskMitigation a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "Definition of freedom from health risk, ISO/IEC 25019:2023,3.2.2.3"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:RiskMitigation ;
    skos:definition "Extent to which a product or system  mitigates the potential risk to people’s health in the intended contexts of use"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Health Risk Mitigation"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:HumanLifeRiskMitigation a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "Definition of freedom from human life risk, ISO/IEC 25019:2023,3.2.2.4"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:RiskMitigation ;
    skos:definition "Extent to which a product  or system mitigates the potential risk to people’s lives in the intended contexts of use"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Human Life Risk Mitigation"@en ;
    dqv:inCategory iso-25059:QualityInUse .

iso-25059:Inclusivity a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC 25010:2023, 3.4.6"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:InteractionCapability ;
    skos:definition "Capability of a product to be utilised by people of various backgrounds"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Inclusivity"@en ;
    dqv:inCategory iso-25059:ProductQuality .

iso-25059:Initiative a rdfs:Class,
        skos:Concept,
        dqv:Dimension ;
    dct:source "ISO/IEC TS 25011:2017, 3.2.7.2,  IT service is replaced by AI service"@en ;
    rdfs:isDefinedBy iso-25059: ;
    sw:term_status "accepted"@en ;
    skos:broader iso-25059:ServiceAdaptability ;
    skos:definition "Degree to which the AI service recognizes users’ goals and service suggests changes to meet users’ needs"@en ;
    skos:inScheme iso-25059:core-classes ;
    skos:prefLabel "Initiative"@en ;
    dqv:inCategory iso-25059:AIServiceQuality .

iso-25059:Installability a rdfs:Class,
        skos:Concept,
