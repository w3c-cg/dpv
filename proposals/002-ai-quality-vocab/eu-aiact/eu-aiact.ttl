    rdfs:isDefinedBy eu-aiact: ;
    sw:term_status "accepted"@en ;
    skos:broader dqv:Dimension ;
    skos:inScheme eu-aiact:core-classes ;
    skos:prefLabel "Accuracy"@en ;
    dqv:inCategory eu-aiact:SystemQuality .

